{
  "name": "cf-blitz",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client",
    "postinstall": "node -e \"const fs=require('fs');const {execSync}=require('child_process');if(!fs.existsSync('client/node_modules/vite')){execSync('npm install --prefix client --production=false',{stdio:'inherit'});}\"",
    "start": "npm run build && npm run start:serve --prefix server"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
